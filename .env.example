POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev
POSTGRES_DB=pdc
DATABASE_URL=postgresql://postgres:dev@localhost:5432/pdc

# Drivers
STORAGE_DRIVER=local        # local | s3
QUEUE_DRIVER=postgres       # postgres | redis
ASR_DRIVER=whisper-local    # whisper-local | openai | deepgram
STORAGE_DIR=./.data/media

AUTH_SECRET=dev-insecure-change-me

