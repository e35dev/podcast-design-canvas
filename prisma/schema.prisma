// Relational data. Every tenant-owned table carries workspaceId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  episodes  Episode[]
  templates Template[]
  brandKits BrandKit[]
  guests    GuestProfile[]
  glossary  GlossaryEntry[]
  assets    Asset[]
  sponsors  Sponsor[]
  jobs      Job[]
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
}

model Episode {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  title       String
  document    Json // EditDocument
  templateId  String?
  template    Template?     @relation(fields: [templateId], references: [id])
  tracks      SpeakerTrack[]
  segments    Segment[]
  reviewCopies ReviewCopy[]
  versions    Version[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([workspaceId])
}

model SpeakerTrack {
  id        String   @id @default(cuid())
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id])
  role      String
  name      String?
  mediaKey  String?
  hasVideo  Boolean  @default(true)
  durationS Int      @default(0)

  @@index([episodeId])
}

model Template {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  spec        Json
  episodes    Episode[]
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model BrandKit {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  spec        Json

  @@index([workspaceId])
}

model GuestProfile {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  displayName String
  details     Json

  @@index([workspaceId])
}

model GlossaryEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  term        String
  spelling    String
  note        String?

  @@index([workspaceId])
}

model Segment {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id])
  kind      String
  order     Int

  @@index([episodeId])
}

model Asset {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  kind        String
  storageKey  String
  approved    Boolean   @default(false)

  @@index([workspaceId])
}

model Sponsor {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  spec        Json

  @@index([workspaceId])
}

model ReviewCopy {
  id        String   @id @default(cuid())
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id])
  status    String   @default("open")
  createdAt DateTime @default(now())

  @@index([episodeId])
}

model Version {
  id        String   @id @default(cuid())
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id])
  event     String
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([episodeId])
}

// Postgres-backed job queue.
model Job {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  type        String
  status      String    @default("pending")
  payload     Json
  result      Json?
  progress    Int       @default(0)
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([workspaceId])
}
